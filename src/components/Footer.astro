---
import ChromeRule from './ChromeRule.astro';
---

<footer>
	<ChromeRule />
	<div class="row">
		<span class="meta">© EL · est. 2022 · chicago &amp; sf</span>
	</div>
</footer>

<style>
	footer {
		margin-top: 80px;
	}
	.row {
		display: flex;
		justify-content: flex-end;
		align-items: baseline;
		margin-top: 22px;
		font-family: var(--mono);
		font-size: 11px;
		letter-spacing: 0.04em;
	}
	.meta {
		color: var(--ink-faint);
	}
</style>
