---
import HeaderLink from './HeaderLink.astro';
import SkullMark from './SkullMark.astro';
---

<header>
	<a class="brand" href="/">
		<SkullMark size={28} />
		<span class="wordmark">limchayseng<span class="tld">.com</span></span>
	</a>
	<nav>
		<HeaderLink href="/">writing</HeaderLink>
		<HeaderLink href="/about">about</HeaderLink>
	</nav>
</header>

<style>
	header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 11px;
		text-decoration: none;
		color: inherit;
	}
	.wordmark {
		font-family: var(--sans);
		font-size: 16px;
		font-weight: 500;
		letter-spacing: -0.005em;
		color: var(--ink);
	}
	.tld {
		color: var(--ink-mute);
		font-weight: 400;
	}
	nav {
		display: flex;
		gap: 22px;
		align-items: center;
	}
</style>
