---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ChromeRule from '../components/ChromeRule.astro';
import CornerMarks from '../components/CornerMarks.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SkullMark from '../components/SkullMark.astro';

type Props = CollectionEntry<'blog'>['data'] & { readMinutes?: number };

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags,
	tag,
	resultLabel,
	marginNotes,
	stravaStats,
	readMinutes,
} = Astro.props;

function capitalize(s: string) {
	return s.charAt(0).toUpperCase() + s.slice(1);
}

// "Filed" block — prefer up to three tags, formatted; fall back to the single `tag` field.
const filed: string[] = (() => {
	if (tags && tags.length) return tags.slice(0, 3).map(capitalize);
	if (tag) return [tag];
	return [];
})();

const hasMarginNotes = !!(marginNotes && marginNotes.length);
const hasStrava = !!stravaStats;
const hasRightRail = hasMarginNotes || hasStrava;
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description ?? `${title} — limchayseng.com`}
		/>
	</head>
	<body>
		<div class="page">
			<CornerMarks />
			<Header />

			<article class={`post${hasRightRail ? '' : ' no-right'}`}>
				<!-- LEFT META GUTTER -->
				<aside class="gutter-left">
					<SkullMark size={32} />

					{filed.length > 0 && (
						<>
							<div class="label meta-mono">Filed</div>
							<div class="filed">
								{filed.map((f) => (
									<div>{f}</div>
								))}
							</div>
						</>
					)}

					<div class="label meta-mono">Date</div>
					<div class="value">
						<FormattedDate date={pubDate} format="ymd" />
					</div>

					{updatedDate && (
						<>
							<div class="label meta-mono">Updated</div>
							<div class="value">
								<FormattedDate date={updatedDate} format="ymd" />
							</div>
						</>
					)}

					{readMinutes && (
						<>
							<div class="label meta-mono">Read</div>
							<div class="value">~{readMinutes} min</div>
						</>
					)}

					{resultLabel && (
						<>
							<div class="label meta-mono">Result</div>
							<div class="value result">● {resultLabel}</div>
						</>
					)}

					<ChromeRule maxWidth="60px" margin="28px 0 0" />
				</aside>

				<!-- CENTER BODY -->
				<div class="body">
					<h1>{title}</h1>
					<ChromeRule margin="36px 0" />
					<div class="prose">
						<slot />
					</div>
				</div>

				<!-- RIGHT MARGIN-NOTES GUTTER -->
				{hasRightRail && (
					<aside class="gutter-right">
						{hasMarginNotes &&
							marginNotes!.map((n) => (
								<div class="mnote">
									<div class="mnote-id">§{n.id}</div>
									<div class="mnote-text">{n.text}</div>
								</div>
							))}
						{hasStrava && (
							<>
								<ChromeRule margin="24px 0" />
								<div class="label meta-mono">Strava</div>
								<pre class="strava">{stravaStats}</pre>
							</>
						)}
					</aside>
				)}
			</article>

			<Footer />
		</div>

		<style>
			.page {
				position: relative;
				padding: 56px 96px;
				min-height: 100vh;
			}

			.post {
				margin-top: 64px;
				display: grid;
				grid-template-columns: 160px 700px 1fr;
				gap: 48px;
				align-items: start;
			}
			.post.no-right {
				grid-template-columns: 160px 700px;
			}

			/* — left gutter ————————————————— */
			.gutter-left {
				padding-top: 6px;
			}
			.gutter-left .label {
				margin-top: 22px;
			}
			.gutter-left .label:first-of-type {
				margin-top: 22px;
			}
			.filed {
				font-family: var(--sans);
				font-size: 13.5px;
				line-height: 1.55;
				color: var(--ink-soft);
				margin-top: 4px;
			}
			.value {
				font-family: var(--mono);
				font-size: 12px;
				color: var(--ink);
				margin-top: 4px;
			}
			.value.result {
				color: var(--hanko);
			}

			/* — body ————————————————— */
			.body {
				min-width: 0;
			}
			.body h1 {
				font-family: var(--sans);
				font-weight: 500;
				font-size: 46px;
				line-height: 1.08;
				letter-spacing: -0.035em;
				margin: 0;
				color: var(--ink);
			}

			/* — right gutter ————————————————— */
			.gutter-right {
				padding-top: 6px;
				font-family: var(--mono);
				font-size: 11.5px;
				color: var(--ink-mute);
				line-height: 1.55;
				letter-spacing: 0.01em;
			}
			.mnote {
				margin-bottom: 28px;
			}
			.mnote-id {
				color: var(--hanko);
			}
			.mnote-text {
				margin-top: 4px;
			}
			.strava {
				font-family: var(--mono);
				font-size: 11.5px;
				color: var(--ink);
				font-variant-numeric: tabular-nums;
				white-space: pre-wrap;
				margin: 8px 0 0;
				line-height: 1.55;
			}

			/* — responsive ————————————————— */
			@media (max-width: 1180px) {
				.post,
				.post.no-right {
					grid-template-columns: 160px minmax(0, 700px);
				}
				.gutter-right {
					grid-column: 2;
					padding-top: 24px;
					border-top: 1px solid var(--paper-edge);
					margin-top: 36px;
				}
			}

			@media (max-width: 820px) {
				.page {
					padding: 48px 40px;
				}
				.post,
				.post.no-right {
					grid-template-columns: 1fr;
					gap: 28px;
				}
				.gutter-left {
					display: grid;
					grid-template-columns: auto 1fr;
					column-gap: 14px;
					row-gap: 6px;
					align-items: baseline;
					padding-top: 0;
				}
				.gutter-left :global(img.skull-mark) {
					grid-column: 1 / -1;
				}
				.gutter-left .label {
					margin-top: 0;
				}
				.body h1 {
					font-size: 36px;
				}
				.gutter-right {
					grid-column: 1;
					padding-top: 16px;
					margin-top: 16px;
				}
			}

			@media (max-width: 720px) {
				.page {
					padding: 36px 22px;
				}
				.body h1 {
					font-size: 32px;
				}
			}
		</style>
	</body>
</html>
