---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ChromeRule from '../components/ChromeRule.astro';
import CornerMarks from '../components/CornerMarks.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RunningThoughtsRail from '../components/RunningThoughtsRail.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const SOCIALS = [
	{ label: 'github', href: 'https://github.com/elimchayseng' },
	{ label: 'strava', href: 'https://www.strava.com/athletes/44108500' },
	{ label: 'linkedin', href: 'https://www.linkedin.com/in/elimchayseng/' },
	{ label: 'email', href: 'mailto:elimchayseng13@gmail.com' },
];

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const years = posts.map((p) => p.data.pubDate.getFullYear());
const minYear = years.length ? Math.min(...years) : new Date().getFullYear();
const maxYear = years.length ? Math.max(...years) : new Date().getFullYear();
const yearRange = minYear === maxYear ? `${minYear}` : `${minYear} – ${maxYear}`;

function capitalize(s: string | undefined) {
	if (!s) return '';
	return s.charAt(0).toUpperCase() + s.slice(1);
}

function tagFor(p: (typeof posts)[number]) {
	if (p.data.tag) return p.data.tag;
	const first = p.data.tags?.[0];
	return capitalize(first);
}

// Annotate each post with its display year so the template can detect year changes.
let lastYear: number | null = null;
const rows = posts.map((p) => {
	const y = p.data.pubDate.getFullYear();
	const yearBreak = lastYear !== y;
	lastYear = y;
	return { post: p, yearBreak, year: y };
});

const SPINE_TICKS = [0.18, 0.36, 0.55, 0.78];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="page">
			<CornerMarks />

			<div class="spine" aria-hidden="true"></div>
			{SPINE_TICKS.map((t) => (
				<div
					class="spine-tick"
					aria-hidden="true"
					style={`top: calc(90px + (100% - 180px) * ${t});`}
				></div>
			))}

			<Header />

			<section class="hero">
				<div class="hero-row">
					<h1>Posts</h1>
					<div class="socials">
						{
							SOCIALS.map((s, i) => (
								<>
									{i > 0 && <span class="sep">·</span>}
									<a
										class="social"
										href={s.href}
										target={s.href.startsWith('mailto') ? undefined : '_blank'}
										rel={s.href.startsWith('mailto') ? undefined : 'noopener'}
									>
										<span>{s.label}</span>
										<span class="arrow">↗</span>
									</a>
								</>
							))
						}
					</div>
				</div>
			</section>

			<section class="content">
				<div class="list">
					{
						rows.map(({ post, yearBreak, year }, idx) => (
							<>
								{yearBreak && (
									<div class={`year-break${idx === 0 ? ' first' : ''}`}>
										<span class="year">[ {year} ]</span>
									</div>
								)}
								<a class={`row${yearBreak ? ' no-border' : ''}`} href={`/blog/${post.id}/`}>
									<div class="row-main">
										<span class="date">
											<FormattedDate date={post.data.pubDate} format="mmdd" />
										</span>
										<span class="title">{post.data.title}</span>
										<span class="tag">{tagFor(post)}</span>
									</div>
									{post.data.note && (
										<div class="note">
											<span class="star">✱</span>
											{post.data.note}
										</div>
									)}
								</a>
							</>
						))
					}
				</div>

				<div class="right-col">
					<span class="meta-mono entries">{posts.length} entries · {yearRange}</span>
					<RunningThoughtsRail />
				</div>
			</section>

			<Footer />
		</div>

		<style>
			.page {
				position: relative;
				padding: 56px 96px 56px 130px;
				min-height: 100vh;
			}
			.spine {
				position: absolute;
				left: 56px;
				top: 90px;
				bottom: 90px;
				width: 1px;
				background: linear-gradient(
					180deg,
					transparent 0%,
					var(--chrome) 4%,
					var(--chrome) 96%,
					transparent 100%
				);
				opacity: 0.4;
				pointer-events: none;
			}
			.spine-tick {
				position: absolute;
				left: 50px;
				width: 12px;
				height: 1px;
				background: var(--chrome-dim);
				opacity: 0.55;
				pointer-events: none;
			}

			.hero {
				margin-top: 64px;
			}
			.hero-row {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 24px;
			}
			.hero h1 {
				font-family: var(--sans);
				font-weight: 500;
				font-size: 44px;
				letter-spacing: -0.03em;
				line-height: 1;
				margin: 0;
				color: var(--ink);
			}
			.entries {
				white-space: nowrap;
			}

			.content {
				margin-top: 40px;
				display: grid;
				grid-template-columns: 1fr 280px;
				gap: 80px;
				align-items: start;
			}

			.list {
				min-width: 0;
			}

			.right-col {
				display: flex;
				flex-direction: column;
				gap: 28px;
			}
			.right-col .entries {
				padding-left: 28px;
			}
			.socials {
				display: flex;
				align-items: baseline;
				flex-wrap: wrap;
				gap: 12px;
				font-family: var(--mono);
				font-size: 11.5px;
				letter-spacing: 0.04em;
			}
			.sep {
				color: var(--ink-faint);
			}
			.social {
				display: inline-flex;
				align-items: baseline;
				gap: 5px;
				color: var(--ink-mute);
				text-decoration: none;
				transition: color 200ms ease;
			}
			.social:hover {
				color: var(--ink);
			}
			.arrow {
				color: var(--ink-faint);
			}

			.year-break {
				display: flex;
				align-items: baseline;
				padding: 24px 0 8px;
			}
			.year-break.first {
				padding-top: 4px;
			}
			.year {
				font-family: var(--mono);
				font-size: 11px;
				color: var(--chrome-dim);
				letter-spacing: 0.18em;
				text-transform: uppercase;
			}

			.row {
				display: block;
				text-decoration: none;
				color: inherit;
				padding: 14px 0;
				border-top: 1px solid rgba(239, 233, 221, 0.06);
				transition: color 200ms ease;
			}
			.row.no-border {
				border-top: none;
			}
			.row-main {
				display: flex;
				align-items: baseline;
				gap: 14px;
			}
			.date {
				font-family: var(--mono);
				font-size: 11.5px;
				color: var(--ink-mute);
				letter-spacing: 0.02em;
				width: 50px;
				font-variant-numeric: tabular-nums;
				flex-shrink: 0;
			}
			.title {
				font-family: var(--sans);
				font-weight: 400;
				font-size: 20px;
				color: var(--ink);
				flex: 1;
				letter-spacing: -0.014em;
				line-height: 1.3;
				transition: color 200ms ease;
			}
			.tag {
				font-family: var(--mono);
				font-size: 10.5px;
				color: var(--ink-faint);
				letter-spacing: 0.14em;
				text-transform: uppercase;
				white-space: nowrap;
				flex-shrink: 0;
			}
			.row:hover .title {
				color: var(--hanko);
			}
			.note {
				padding-left: 64px;
				margin-top: 4px;
				font-family: var(--serif);
				font-style: italic;
				font-size: 14px;
				color: var(--ink-mute);
				line-height: 1.4;
			}
			.star {
				color: var(--hanko);
				margin-right: 8px;
			}

			@media (max-width: 1024px) {
				.page {
					padding: 48px 56px 48px 96px;
				}
				.content {
					grid-template-columns: 1fr 240px;
					gap: 56px;
				}
			}

			@media (max-width: 820px) {
				.page {
					padding: 48px 40px;
				}
				.spine,
				.spine-tick {
					display: none;
				}
				.content {
					grid-template-columns: 1fr;
					gap: 56px;
				}
				.right-col .entries {
					padding-left: 0;
				}
			}

			@media (max-width: 720px) {
				.page {
					padding: 40px 24px;
				}
				.hero h1 {
					font-size: 32px;
				}
				.hero-row {
					flex-direction: column;
					gap: 8px;
				}
				.title {
					font-size: 17px;
				}
				.row-main {
					gap: 10px;
					flex-wrap: wrap;
				}
				.tag {
					width: 100%;
					padding-left: 64px;
					margin-top: 2px;
				}
				.note {
					padding-left: 64px;
				}
			}
		</style>
	</body>
</html>
